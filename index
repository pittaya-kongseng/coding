        // State System
        let currentLevelIdx = 0;
        let charX = 0;
        let charY = 0;
        let charDir = "E"; // N, E, S, W
        let coinsPositions = []; // List of coins in active level
        let collectedCoinsCount = 0;
        let runningAnimation = false;
        let actionsQueue = []; // Actions animation generated by python execution
        let totalScore = 0;

        // On document load
        window.onload = function() {
            // Check cache progress
            const savedLevel = localStorage.getItem("codeventure_level");
            if (savedLevel !== null) {
                currentLevelIdx = parseInt(savedLevel);
                if (currentLevelIdx >= LEVELS.length) currentLevelIdx = 0;
            }
            const savedScore = localStorage.getItem("codeventure_score");
            if (savedScore !== null) {
                totalScore = parseInt(savedScore);
                document.getElementById("totalCoinsCount").textContent = totalScore;
            }

            loadLevel(currentLevelIdx);
        };

        // Load targeted level elements
        function loadLevel(idx) {
            currentLevelIdx = idx;
            localStorage.setItem("codeventure_level", idx);
            
            const level = LEVELS[idx];
            
            // Set Titles/Helps
            document.getElementById("levelIndicator").textContent = level.name;
            document.getElementById("levelObjective").textContent = level.desc;
            document.getElementById("buddyDialog").textContent = level.hint;
            
            // Available Commands Guide Box
            const cmdContainer = document.getElementById("availableCommands");
            cmdContainer.innerHTML = "";
            level.allowedCommands.forEach(cmd => {
                const chip = document.createElement("span");
                chip.className = "bg-[#21262d] text-emerald-400 px-2 py-1 rounded border border-[#30363d] cursor-pointer hover:bg-emerald-500/10 transition";
                chip.innerHTML = `<code class="code-font">${cmd}</code>`;
                chip.onclick = () => {
                    insertCommand(cmd);
                };
                cmdContainer.appendChild(chip);
            });

            // Set Editor template
            document.getElementById("codeEditor").value = level.defaultCode;
            updateLineNumbers();

            // Clear console
            printConsole("เริ่มเล่นระดับ: " + level.name + "\nพิมพ์คำสั่งของคุณทางฝั่งซ้าย", "info");

            // Build visual grid
            initGridState(level);
        }

        // Initialize state inside current grid
        function initGridState(level) {
            charX = level.startCol;
            charY = level.startRow;
            charDir = level.startDir;
            collectedCoinsCount = 0;
            coinsPositions = [];

            // Parse levels for coin objects
            for (let r = 0; r < level.height; r++) {
                for (let c = 0; c < level.width; c++) {
                    if (level.grid[r][c] === 2) {
                        coinsPositions.push({ x: c, y: r, collected: false });
                    }
                }
            }

            document.getElementById("capturedCoins").textContent = "0";
            document.getElementById("targetCoins").textContent = coinsPositions.length;

            renderBoard();
        }

        // Render graphical grids
        function renderBoard() {
            const level = LEVELS[currentLevelIdx];
            const board = document.getElementById("gameBoard");
            
            // Dynamic Grid styling based on dimensions
            board.style.gridTemplateColumns = `repeat(${level.width}, minmax(50px, 60px))`;
            board.style.gridTemplateRows = `repeat(${level.height}, minmax(50px, 60px))`;
            
            board.innerHTML = "";

            // Create grids
            for (let r = 0; r < level.height; r++) {
                for (let c = 0; c < level.width; c++) {
                    const cell = document.createElement("div");
                    cell.className = "relative rounded-xl border flex items-center justify-center transition-all duration-300 select-none overflow-hidden ";
                    
                    const cellType = level.grid[r][c];
                    
                    if (cellType === 0) {
                        // Void Space (Water or empty dark area)
                        cell.className += "bg-slate-950/80 border-slate-900";
                    } else {
                        // Walkable paths
                        cell.className += "bg-[#182a5c] border-blue-500/10 shadow-inner";
                    }

                    // Draw Coin if available and not collected
                    const coinHere = coinsPositions.find(coin => coin.x === c && coin.y === r && !coin.collected);
                    if (coinHere) {
                        const coinImg = document.createElement("div");
                        coinImg.className = "absolute z-10 w-9 h-9 bg-yellow-500 rounded-full flex items-center justify-center border-2 border-yellow-300 shadow-lg shadow-yellow-500/50 animate-coin text-amber-900 font-extrabold text-sm";
                        coinImg.innerHTML = `<i class="fa-solid fa-star"></i>`;
                        cell.appendChild(coinImg);
                    }

                    // Draw Player Character Bot on current dynamic position
                    if (charX === c && charY === r) {
                        const player = document.createElement("div");
                        player.className = "absolute z-20 w-11 h-11 bg-gradient-to-tr from-rose-500 to-amber-400 rounded-2xl flex items-center justify-center border-2 border-white shadow-xl shadow-rose-500/30 character-transition";
                        
                        // Add direction indicators (Face)
                        let rotationClass = "rotate-0";
                        if (charDir === "E") rotationClass = "rotate-0";
                        else if (charDir === "S") rotationClass = "rotate-90";
                        else if (charDir === "W") rotationClass = "rotate-180";
                        else if (charDir === "N") rotationClass = "-rotate-90";
                        
                        player.className += " " + rotationClass;

                        // Robot cute SVG
                        player.innerHTML = `
                            <svg class="w-8 h-8 text-white transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <!-- Direction beacon hat pointer -->
                            <div class="absolute -top-1 left-1/2 -translate-x-1/2 w-2 h-2 bg-white rounded-full"></div>
                        `;
                        cell.appendChild(player);
                    }

                    board.appendChild(cell);
                }
            }
        }

        // Reset levels without reset overall coins
        function resetLevelState() {
            if (runningAnimation) return;
            initGridState(LEVELS[currentLevelIdx]);
            printConsole("รีเซ็ตตำแหน่งตัวละครเรียบร้อยแล้ว!", "info");
        }

        // Change Level Button handlers
        function changeLevel(dir) {
            if (runningAnimation) return;
            let targetIdx = currentLevelIdx + dir;
            if (targetIdx >= 0 && targetIdx < LEVELS.length) {
                loadLevel(targetIdx);
            }
        }

        // Custom Helper alert
        function customAlert(title, text, type = "error") {
            document.getElementById("alertTitle").textContent = title;
            document.getElementById("alertMessage").textContent = text;
            
            const icon = document.getElementById("alertIcon");
            if (type === "error") {
                icon.className = "fa-solid fa-triangle-exclamation text-xl";
                icon.parentElement.className = "w-12 h-12 bg-red-500/10 rounded-full flex items-center justify-center mx-auto mb-3 text-red-500 border border-red-500/20";
            } else {
                icon.className = "fa-solid fa-circle-info text-xl";
                icon.parentElement.className = "w-12 h-12 bg-blue-500/10 rounded-full flex items-center justify-center mx-auto mb-3 text-blue-400 border border-blue-500/20";
            }

            document.getElementById("alertModal").classList.remove("hidden");
        }

        function closeAlert() {
            document.getElementById("alertModal").classList.add("hidden");
        }

        // Level Accomplished triggers
        function showSuccessClear() {
            document.getElementById("successModal").classList.remove("hidden");
            
            // Count number of unique cleared levels
            let clearedCount = parseInt(localStorage.getItem("codeventure_cleared_count") || "0");
            let hasBeenCleared = localStorage.getItem(`codeventure_cleared_level_${currentLevelIdx}`);
            if (!hasBeenCleared) {
                localStorage.setItem(`codeventure_cleared_level_${currentLevelIdx}`, "true");
                clearedCount++;
                localStorage.setItem("codeventure_cleared_count", clearedCount);
            }
            
            document.getElementById("totalCoinsCount").textContent = clearedCount;
        }

        function closeSuccessModal() {
            document.getElementById("successModal").classList.add("hidden");
        }

        // Go to next levels
        function goToNextLevel() {
            closeSuccessModal();
            if (currentLevelIdx + 1 < LEVELS.length) {
                loadLevel(currentLevelIdx + 1);
            } else {
                customAlert("ฉลองความยินดี 🎉", "คุณพิชิตด่านครบทั้ง 20 ด่านหลักแล้ว ยอดเยี่ยมที่สุดในการเรียนภาษา Python!", "info");
            }
        }

        // Console printing utils
        function printConsole(text, type = "info") {
            const consoleOutput = document.getElementById("consoleOutput");
            let prefix = "";
            let colorClass = "text-[#c9d1d9]";
            
            if (type === "error") {
                prefix = "[Error] ❌ ";
                colorClass = "text-rose-400";
            } else if (type === "success") {
                prefix = "[Success] ⭐ ";
                colorClass = "text-emerald-400 font-bold";
            } else if (type === "system") {
                prefix = "[System] ⚙️ ";
                colorClass = "text-blue-400";
            }

            consoleOutput.innerHTML = `<span class="${colorClass}">${prefix}${text}</span>`;
            consoleOutput.scrollTop = consoleOutput.scrollHeight;
        }

        // Auto generation of Line numbers
        function updateLineNumbers() {
            const textarea = document.getElementById("codeEditor");
            const lineNumbers = document.getElementById("lineNumbers");
            const lines = textarea.value.split('\n');
            const maxLines = Math.max(lines.length, 12);
            let numHTML = '';
            for (let i = 1; i <= maxLines; i++) {
                numHTML += i + '<br>';
            }
            lineNumbers.innerHTML = numHTML;
        }

        // Insert code template directly in text cursor
        function insertCommand(cmd) {
            const textarea = document.getElementById("codeEditor");
            let cleanCmd = cmd;
            if (cmd === "move_forward(steps)") cleanCmd = "move_forward(1)";
            else if (cmd === "for i in range(N):") cleanCmd = "for i in range(3):\n    move_forward(1)";

            const startPos = textarea.selectionStart;
            const endPos = textarea.selectionEnd;
            textarea.value = textarea.value.substring(0, startPos) + cleanCmd + textarea.value.substring(endPos, textarea.value.length);
            textarea.focus();
            updateLineNumbers();
        }

        function insertTemplate() {
            const level = LEVELS[currentLevelIdx];
            document.getElementById("codeEditor").value = level.defaultCode;
            updateLineNumbers();
        }

        // Full Interactive Parser Simulator for Python (REBUILT FOR COMPILATION FIXES)
        function runPythonCode() {
            if (runningAnimation) return;

            const codeText = document.getElementById("codeEditor").value;
            printConsole("กำลังแปลงโค้ด Python และวิเคราะห์...", "system");

            // Reset level to initial state before simulated running
            const level = LEVELS[currentLevelIdx];
            charX = level.startCol;
            charY = level.startRow;
            charDir = level.startDir;
            collectedCoinsCount = 0;
            
            // Reload coins
            coinsPositions.forEach(coin => coin.collected = false);
            renderBoard();

            // Setup actions queue
            actionsQueue = [];
            
            // Build AST or simple line instructions
            const lines = codeText.split('\n');
            let hasError = false;
            let errorText = "";

            // Parser simulator state loop
            let i = 0;
            while (i < lines.length) {
                let rawLine = lines[i];
                let line = rawLine.trim();
                
                // [FIXED] Skip empty lines or comments BEFORE checking any errors (like checking "_" or indentations)
                if (line === "" || line.startsWith("#")) {
                    i++;
                    continue;
                }

                // [SUPER-FIXED] Exclude ALL legitimate functions (with underscore) before validating placeholder check!
                const underscoreCheckLine = line
                    .replace(/move_forward/g, "")
                    .replace(/turn_left/g, "")
                    .replace(/turn_right/g, "");
                    
                if (underscoreCheckLine.includes("_")) {
                    hasError = true;
                    errorText = `ตรวจพบอักขระว่าง '_' ที่บรรทัด ${i + 1}. กรุณาระบุเป็นตัวเลขก้าวเดินแทน เช่น: move_forward(5) หรือ turn_left(1)`;
                    break;
                }

                // Match basic for loop
                // "for i in range(N):"
                const forMatch = line.match(/^for\s+(\w+)\s+in\s+range\s*\(\s*(\d+)\s*\)\s*:/);
                if (forMatch) {
                    const loopVar = forMatch[1];
                    const loopCount = parseInt(forMatch[2]);
                    
                    if (isNaN(loopCount) || loopCount <= 0) {
                        hasError = true;
                        errorText = `โครงสร้าง Loop 'range' ต้องใส่จำนวนรอบที่ถูกต้องที่บรรทัด ${i + 1}`;
                        break;
                    }

                    // Look for indented blocks below this loop
                    let blockLines = [];
                    let j = i + 1;
                    while (j < lines.length) {
                        const nextRawLine = lines[j];
                        const nextLine = nextRawLine.trim();
                        
                        // If empty line or comment, we can skip or include it safely
                        if (nextLine === "" || nextLine.startsWith("#")) {
                            j++;
                            continue;
                        }
                        
                        // Check if line is indented with spaces
                        const indentMatch = nextRawLine.match(/^(\s+)(.*)/);
                        if (indentMatch && indentMatch[1].length >= 2) {
                            blockLines.push(indentMatch[2].trim());
                            j++;
                        } else {
                            break; // Out of loop block
                        }
                    }

                    if (blockLines.length === 0) {
                        hasError = true;
                        errorText = `ข้อผิดพลาดการย่อหน้า (IndentationError): บรรทัดที่ ${i + 2} คาดหวังการย่อหน้าย่อยภายใต้เงื่อนไข For Loop`;
                        break;
                    }

                    // Duplicate the action block
                    for (let c = 0; c < loopCount; c++) {
                        for (let b = 0; b < blockLines.length; b++) {
                            const subLine = blockLines[b];
                            if (subLine === "" || subLine.startsWith("#")) continue;
                            
                            // Prevent inner "_" (excluding actual underscored commands)
                            const subUnderscoreCheck = subLine
                                .replace(/move_forward/g, "")
                                .replace(/turn_left/g, "")
                                .replace(/turn_right/g, "");
                                
                            if (subUnderscoreCheck.includes("_")) {
                                hasError = true;
                                errorText = `ตรวจพบอักขระว่าง '_' ภายใต้ลูปบรรทัดที่ ${i + 1}. กรุณาระบุเป็นตัวเลขในวงเล็บ`;
                                break;
                            }
                            
                            const parsed = parseSingleCommand(subLine, i + 1 + b);
                            if (parsed.error) {
                                hasError = true;
                                errorText = parsed.error;
                                break;
                            }
                        }
                        if (hasError) break;
                    }

                    if (hasError) break;
                    i = j; // Advance outer index
                    continue;
                }

                // Check for unexpected Indent on regular line
                const indentMatch = rawLine.match(/^(\s+)(.*)/);
                if (indentMatch && indentMatch[1].length > 0) {
                    hasError = true;
                    errorText = `การย่อหน้าไม่ถูกต้อง (IndentationError) ที่บรรทัด ${i + 1}`;
                    break;
                }

                // Parse standard linear action
                const parsed = parseSingleCommand(line, i + 1);
                if (parsed.error) {
                    hasError = true;
                    errorText = parsed.error;
                    break;
                }

                i++;
            }

            if (hasError) {
                printConsole(errorText, "error");
                customAlert("มีข้อผิดพลาดทางไวยากรณ์!", errorText, "error");
                return;
            }

            // Run Simulator queue on layout
            if (actionsQueue.length === 0) {
                printConsole("ไม่พบชุดคำสั่งทำงาน กรุณาลองพิมพ์ย่อหน้าหรือเช็คเครื่องหมายวงเล็บ", "error");
                return;
            }

            executeAnimationChain();
        }

        // Match individual actions (UPGRADED to support turn params)
        function parseSingleCommand(line, lineNum) {
            // move_forward(N)
            const moveMatch = line.match(/^move_forward\s*\(\s*(\d*)\s*\)/);
            if (moveMatch) {
                let steps = moveMatch[1] === "" ? 1 : parseInt(moveMatch[1]);
                for (let s = 0; s < steps; s++) {
                    actionsQueue.push({ type: "move", line: lineNum });
                }
                return { success: true };
            }

            // turn_left(N) or turn_left()
            const leftMatch = line.match(/^turn_left\s*\(\s*(\d*)\s*\)/);
            if (leftMatch) {
                let steps = leftMatch[1] === "" ? 1 : parseInt(leftMatch[1]);
                for (let s = 0; s < steps; s++) {
                    actionsQueue.push({ type: "left", line: lineNum });
                }
                return { success: true };
            }

            // turn_right(N) or turn_right()
            const rightMatch = line.match(/^turn_right\s*\(\s*(\d*)\s*\)/);
            if (rightMatch) {
                let steps = rightMatch[1] === "" ? 1 : parseInt(rightMatch[1]);
                for (let s = 0; s < steps; s++) {
                    actionsQueue.push({ type: "right", line: lineNum });
                }
                return { success: true };
            }

            return { error: `ไม่รู้จักคำสั่ง "${line}" ที่บรรทัด ${lineNum}. คำสั่งที่ใช้ได้คือ move_forward(), turn_left(), หรือ turn_right()` };
        }

        // Execute sequential movements visually
        function executeAnimationChain() {
            if (actionsQueue.length === 0) {
                verifyVictoryCondition();
                return;
            }

            runningAnimation = true;
            const action = actionsQueue.shift();
            const level = LEVELS[currentLevelIdx];
            
            printConsole(`กำลังรันคำสั่งบรรทัดที่ ${action.line}...`, "system");

            let hitObstacle = false;

            if (action.type === "left") {
                // Turn Left
                if (charDir === "N") charDir = "W";
                else if (charDir === "W") charDir = "S";
                else if (charDir === "S") charDir = "E";
                else if (charDir === "E") charDir = "N";
            } else if (action.type === "right") {
                // Turn Right
                if (charDir === "N") charDir = "E";
                else if (charDir === "E") charDir = "S";
                else if (charDir === "S") charDir = "W";
                else if (charDir === "W") charDir = "N";
            } else if (action.type === "move") {
                // Calc next steps coordinates
                let nextX = charX;
                let nextY = charY;

                if (charDir === "N") nextY--;
                else if (charDir === "E") nextX++;
                else if (charDir === "S") nextY++;
                else if (charDir === "W") nextX--;

                // Check bounds and collision
                if (nextX < 0 || nextX >= level.width || nextY < 0 || nextY >= level.height) {
                    hitObstacle = true;
                } else if (level.grid[nextY][nextX] === 0) {
                    hitObstacle = true;
                } else {
                    // Valid step
                    charX = nextX;
                    charY = nextY;

                    // Eat coins
                    const activeCoin = coinsPositions.find(coin => coin.x === charX && coin.y === charY && !coin.collected);
                    if (activeCoin) {
                        activeCoin.collected = true;
                        collectedCoinsCount++;
                        document.getElementById("capturedCoins").textContent = collectedCoinsCount;
                        printConsole("สุดยอด! เก็บเหรียญเพิ่มสำเร็จ!", "success");
                    }
                }
            }

            renderBoard();

            if (hitObstacle) {
                runningAnimation = false;
                printConsole("โอย! ตกเหวหรือเดินชนผนังตารางด้านข้างซะแล้ว!", "error");
                customAlert("ชนสิ่งกีดขวาง!", "ตัวละครชนเหวหรือขอบแผนที่ กรุณารีเซ็ตแล้วปรับโค้ดความยาวช่องให้ถูกต้อง", "error");
                return;
            }

            // Loop again
            setTimeout(executeAnimationChain, 500);
        }

        // Checking targets accomplishment
        function verifyVictoryCondition() {
            runningAnimation = false;
            const totalTargetCoins = coinsPositions.length;

            if (collectedCoinsCount === totalTargetCoins) {
                printConsole("ยอดเยี่ยมมาก! คุณผ่านด่านอย่างสมบูรณ์!", "success");
                showSuccessClear();
            } else {
                printConsole("คำสั่งเสร็จสิ้น แต่คุณยังไม่ได้เก็บเหรียญทองให้ครบเลย!", "error");
                customAlert("เก็บเหรียญไม่ครบ!", "ลองปรับจำนวนก้าวเดินหรือเขียนโค้ดเพิ่มเพื่อไปให้ถึงตำแหน่งเหรียญนะครับ", "error");
            }
        }

        // UI toggles
        function openHelpModal() {
            document.getElementById("helpModal").classList.remove("hidden");
        }

        function closeHelpModal() {
            document.getElementById("helpModal").classList.add("hidden");
        }

        function resetWholeProgress() {
            if (confirm("คุณต้องการล้างคะแนนและความคืบหน้าทั้งหมดหรือไม่?")) {
                localStorage.clear();
                totalScore = 0;
                document.getElementById("totalCoinsCount").textContent = "0";
                loadLevel(0);
            }
        }
    </script>
